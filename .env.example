# MongoDB credentials for QA tools (mongo-extractor.py)
# Copy to .env and fill with real values
# NEVER commit .env with real credentials
#
# Usage:
#   python3 data/mongo-extractor.py --env staging --output data/qa-matrix-staging.json
#   python3 data/mongo-extractor.py --env production

# ── PRODUCCIÓN (youorder.me) ──────────────────────────────────
# Microservices cluster — feature flags, promotions, banners
MONGO_MICRO_URI=mongodb+srv://user:password@microservices-cluster.example.net/

# Legacy cluster — products, orders, customers, salesterms
MONGO_LEGACY_URI=mongodb+srv://user:password@legacy-cluster.example.net/

# Integrations cluster — segments, overrides, user segments
MONGO_INTEGRATIONS_URI=mongodb+srv://user:password@integrations-cluster.example.net/

# ── STAGING (solopide.me) ─────────────────────────────────────
MONGO_MICRO_STAGING_URI=mongodb+srv://user:password@microservices-staging-cluster.example.net/
MONGO_LEGACY_STAGING_URI=mongodb+srv://user:password@legacy-staging-cluster.example.net/
MONGO_INTEGRATIONS_STAGING_URI=mongodb+srv://user:password@integrations-staging-cluster.example.net/
