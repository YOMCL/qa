{
  "cli": {
    "version": ">= 16.17.3",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "node": "22.20.0",
      "developmentClient": true,
      "distribution": "internal"
    },
    "staging": {
      "node": "22.20.0",
      "autoIncrement": false,
      "distribution": "internal",
      "android": {
        "buildType": "apk",
        "gradleCommand": ":app:assembleStaging"
      },
      "env": {
        "APP_ENV": "staging"
      },
      "prebuildCommand": "find android/app/src/main/res -name '*.webp' -type f -delete || true"
    },
    "production": {
      "node": "22.20.0",
      "autoIncrement": true,
      "android": {
        "buildType": "app-bundle"
      },
      "prebuildCommand": "find android/app/src/main/res -name '*.webp' -type f -delete || true"
    },
    "production-apk": {
      "node": "22.20.0",
      "autoIncrement": false,
      "android": {
        "buildType": "apk"
      },
      "prebuildCommand": "find android/app/src/main/res -name '*.webp' -type f -delete || true"
    }
  },
  "submit": {
    "production": {}
  }
}
