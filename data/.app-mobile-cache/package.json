{
  "name": "app-mobile",
  "main": "index.js",
  "version": "1.0.0",
  "scripts": {
    "android:dev": "npm run copy-version && node scripts/copy-google-services.js development && APP_ENV=development expo run:android --variant debug",
    "android:prod": "npm run copy-version && node scripts/copy-google-services.js production && APP_ENV=production expo run:android --variant debug",
    "android:staging": "npm run copy-version && node scripts/copy-google-services.js staging && APP_ENV=staging expo run:android --variant debug",
    "android": "npm run copy-version && expo run:android",
    "build:android:prod": "node scripts/build.js --platform android --profile production",
    "build:android:prod-apk": "node scripts/build.js --platform android --profile production-apk",
    "build:android:staging": "node scripts/build.js --platform android --profile staging --env staging",
    "build:ios:prod": "node scripts/build.js --platform ios --profile production",
    "build:ios:staging": "node scripts/build.js --platform ios --profile staging --env staging",
    "copy-version": "node ./scripts/copy-version.js",
    "ios:dev": "npm run copy-version && APP_ENV=development expo run:ios --variant debug",
    "ios:prod": "npm run copy-version && APP_ENV=production expo run:ios --variant debug",
    "ios:staging": "npm run copy-version && APP_ENV=staging expo run:ios --variant debug",
    "ios": "npm run copy-version && expo run:ios",
    "lint": "expo lint",
    "reset-project": "node ./scripts/reset-project.js",
    "set:version": "eas build:version:set -p android",
    "start:dev": "npm run copy-version && APP_ENV=development expo start",
    "start:prod": "npm run copy-version && APP_ENV=production expo start",
    "start:staging": "npm run copy-version && APP_ENV=staging expo start",
    "start": "npm run copy-version && expo start",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:verbose": "jest --verbose",
    "ts": "tsc --noEmit",
    "web:dev": "npm run copy-version && APP_ENV=development expo start --web",
    "web:prod": "npm run copy-version && APP_ENV=production expo start --web",
    "web:staging": "npm run copy-version && APP_ENV=staging expo start --web",
    "web": "npm run copy-version && expo start --web"
  },
  "dependencies": {
    "@expo/vector-icons": "^14.1.0",
    "@react-native-async-storage/async-storage": "^2.1.0",
    "@react-native/codegen": "^0.79.5",
    "@react-native/js-polyfills": "^0.79.5",
    "@react-navigation/bottom-tabs": "^7.3.10",
    "@react-navigation/drawer": "^7.3.9",
    "@react-navigation/elements": "^2.3.8",
    "@react-navigation/native": "^7.1.6",
    "@react-navigation/stack": "^7.4.7",
    "expo": "53.0.22",
    "expo-blur": "~14.1.5",
    "expo-clipboard": "~7.1.5",
    "expo-constants": "~17.1.7",
    "expo-font": "~13.3.2",
    "expo-haptics": "~14.1.4",
    "expo-image": "~2.4.0",
    "expo-linking": "~7.1.7",
    "expo-router": "~5.1.5",
    "expo-splash-screen": "~0.30.10",
    "expo-status-bar": "~2.2.3",
    "expo-symbols": "~0.4.5",
    "expo-system-ui": "~5.0.11",
    "expo-web-browser": "~14.2.0",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-native": "0.79.5",
    "react-native-app-auth": "^8.0.3",
    "react-native-gesture-handler": "~2.24.0",
    "react-native-paper": "^5.14.5",
    "react-native-reanimated": "~3.17.4",
    "react-native-safe-area-context": "5.4.0",
    "react-native-screens": "~4.11.1",
    "react-native-svg": "15.11.2",
    "react-native-web": "~0.20.0",
    "react-native-webview": "13.13.5"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@react-native-community/cli": "^20.0.0",
    "@react-native/metro-config": "^0.82.0",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^30.0.0",
    "@types/react": "~19.0.10",
    "eslint": "^9.25.0",
    "eslint-config-expo": "~9.2.0",
    "jest": "^29.7.0",
    "jest-expo": "~53.0.10",
    "metro": "^0.82.0",
    "metro-cache": "^0.82.0",
    "metro-config": "^0.82.0",
    "metro-core": "^0.82.0",
    "metro-resolver": "^0.82.0",
    "metro-runtime": "^0.82.0",
    "react-test-renderer": "19.0.0",
    "tsx": "^4.19.2",
    "typescript": "~5.8.3"
  },
  "overrides": {
    "realm": "npm:empty-npm-package@1.0.0"
  },
  "private": true
}
