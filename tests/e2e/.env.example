# Playwright E2E credentials
# Copy to .env and fill with real values
# NEVER commit .env with real credentials

# Default commerce (used by login, cart, checkout, prices specs)
BASE_URL=https://tienda.youorder.me
COMMERCE_EMAIL=user@yom.ai
COMMERCE_PASSWORD=your-password-here

# Multi-client tests (used by multi-client.spec.ts and config-validation.spec.ts)
TIENDA_EMAIL=user@yom.ai
TIENDA_PASSWORD=your-password-here
SOPROLE_EMAIL=user@yom.ai
SOPROLE_PASSWORD=your-password-here
SURTIVENTAS_EMAIL=user@yom.ai
SURTIVENTAS_PASSWORD=your-password-here
MARLEYCOFFEE_EMAIL=user@yom.ai
MARLEYCOFFEE_PASSWORD=your-password-here
CODELPA_EMAIL=user@yom.ai
CODELPA_PASSWORD=your-password-here

# Admin panel tests (used by admin/*.spec.ts)
ADMIN_URL=https://admin.youorder.me
