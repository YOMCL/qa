# Playwright E2E credentials
# Copy to .env and fill with real values
# NEVER commit .env with real credentials

# ── Clientes activos (staging — solopide.me) ──────────────────
# Regenerar clients.ts: python3 tools/sync-clients.py --input data/qa-matrix-staging.json
#
# Clientes activos: CODELPA, SURTIVENTAS, NEW_SOPROLE, PRINORTE, BASTIEN, SONRIE
# Clientes sin credenciales → tests se saltan automáticamente (testInfo.skip)

CODELPA_EMAIL=user@yom.ai
CODELPA_PASSWORD=your-password-here

